{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:energy:messages:E008",
  "title": "E008 – Резултат от проверка на енергийни характеристики на жилище",
  "type": "object",
  "properties": {
    "header": {
      "type": "object",
      "properties": {
        "sender": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "description": "Тип изпращач на съобщението"
        },
        "senderISName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Име и версия на информационната система, изпратила съобщението"
        },
        "recipient": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "description": "Тип на получател на съобщението"
        },
        "messageId": {
          "type": "string",
          "format": "uuid",
          "minLength": 36,
          "maxLength": 36,
          "description": "Уникален идентификатор на текущото съобщение"
        },
        "messageType": {
          "type": "string",
          "const": "E008",
          "description": "Тип на съобщението"
        },
        "createdOn": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}[+-]\\d{2}:\\d{2}$",
          "description": "Дата и час на изготвяне на съобщението по ISO 8601 в локално време с часова зона"
        }
      },
      "required": [
        "sender",
        "senderISName",
        "recipient",
        "messageId",
        "messageType",
        "createdOn"
      ],
      "description": "Системна информация за съобщението"
    },
    "contents": {
      "type": "object",
      "properties": {
        "valueCalculated": {
          "type": "boolean",
          "description": "Изчислена е стойност за специфичния годишен разход на първична енергия на единица площ"
        },
        "value": {
          "type": "number",
          "description": "Стойност за специфичния годишен разход на първична енергия на единица площ | Condition CDX03: IF 'valueCalculated' = TRUE THEN 'value'.required = 'R' ELSE 'value' IS null"
        }
      },
      "required": [
        "valueCalculated"
      ],
      "if": {
        "properties": {
          "valueCalculated": {
            "const": true
          }
        },
        "required": [
          "valueCalculated"
        ]
      },
      "then": {
        "required": [
          "value"
        ]
      },
      "else": {
        "properties": {
          "value": false
        }
      },
      "description": "Съдържание на съобщението"
    }
  },
  "required": [
    "header",
    "contents"
  ]
}