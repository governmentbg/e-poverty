{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:energy:messages:E005",
  "title": "E005 – Заявка за проверка на домакинство",
  "type": "object",
  "properties": {
    "header": {
      "type": "object",
      "properties": {
        "sender": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "description": "Тип изпращач на съобщението"
        },
        "senderISName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Име и версия на информационната система, изпратила съобщението"
        },
        "recipient": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "description": "Тип на получател на съобщението"
        },
        "messageId": {
          "type": "string",
          "format": "uuid",
          "minLength": 36,
          "maxLength": 36,
          "description": "Уникален идентификатор на съобщението - трябва да бъде ново UUID генерирано към момента на изпращане на съобщението"
        },
        "messageType": {
          "type": "string",
          "const": "E005",
          "description": "Тип на съобщението"
        },
        "createdOn": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}[+-]\\d{2}:\\d{2}$",
          "description": "Дата и час на изготвяне на съобщението по ISO 8601 в локално време с часова зона"
        }
      },
      "required": [
        "sender",
        "senderISName",
        "recipient",
        "messageId",
        "messageType",
        "createdOn"
      ],
      "description": "Системна информация за съобщението"
    },
    "contents": {
      "type": "object",
      "properties": {
        "householdMembers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "identifierType": {
                "type": "string",
                "enum": [
                  "1",
                  "2",
                  "3"
                ],
                "description": "Вид идентификатор | Rules: RL002"
              },
              "identifier": {
                "type": "string",
                "description": "ЕГН / ЛНЧ | Rules: RL001"
              }
            },
            "required": [
              "identifierType",
              "identifier"
            ]
          },
          "minItems": 1,
          "description": "Лица от домакинството"
        }
      },
      "required": [
        "householdMembers"
      ],
      "description": "Съдържание на съобщението"
    }
  },
  "required": [
    "header",
    "contents"
  ]
}