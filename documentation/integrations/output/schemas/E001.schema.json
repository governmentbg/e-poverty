{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:energy:messages:E001",
  "title": "E001 – Заявка за извършване на проверка на доход на домакинство (отговор E096 или E098)",
  "type": "object",
  "properties": {
    "header": {
      "type": "object",
      "properties": {
        "sender": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "description": "Тип изпращач на съобщението"
        },
        "senderISName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Име и версия на информационната система, изпратила съобщението"
        },
        "recipient": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "description": "Тип на получател на съобщението"
        },
        "messageId": {
          "type": "string",
          "format": "uuid",
          "minLength": 36,
          "maxLength": 36,
          "description": "Уникален идентификатор на съобщението - трябва да бъде ново UUID генерирано към момента на изпращане на съобщението"
        },
        "messageType": {
          "type": "string",
          "const": "E001",
          "description": "Тип на съобщението"
        },
        "createdOn": {
          "type": "string",
          "pattern": "^\\d{2}-\\d{2}-\\d{4} \\d{2}:\\d{2}:\\d{2}[+-]\\d{2}:\\d{2}$",
          "description": "Дата и час на изготвяне на съобщението по ISO 8601 в локално време с часова зона"
        }
      },
      "required": [
        "sender",
        "senderISName",
        "recipient",
        "messageId",
        "messageType",
        "createdOn"
      ],
      "description": "Системна информация за съобщението"
    },
    "contents": {
      "type": "object",
      "properties": {
        "householdMembers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "identifierType": {
                "type": "string",
                "enum": [
                  "1",
                  "2",
                  "3"
                ],
                "description": "Вид идентификатор"
              },
              "identifier": {
                "type": "string",
                "description": "ЕГН/ЛНЧ/ЛН | Rules: RL001"
              },
              "year": {
                "type": "integer",
                "minimum": 1900,
                "maximum": 2100,
                "description": "Календарна година"
              },
              "hasDeclaration": {
                "type": "boolean",
                "description": "Има подадена декларация по чл. 50 от ЗДДФЛ"
              },
              "nonTaxableIncome": {
                "type": "number",
                "description": "Необлагаеми доходи по чл. 13 от ЗДДФЛ"
              }
            },
            "required": [
              "identifierType",
              "identifier",
              "year",
              "hasDeclaration",
              "nonTaxableIncome"
            ]
          },
          "minItems": 1,
          "description": "Лица от домакинството"
        },
        "energyExpense": {
          "type": "object",
          "properties": {
            "year": {
              "type": "integer",
              "minimum": 1900,
              "maximum": 2100,
              "description": "Календарна година"
            },
            "amount": {
              "type": "number",
              "description": "Стойност на годишен разход за енергия"
            }
          },
          "required": [
            "year",
            "amount"
          ],
          "description": "Данни за разходите за енергия"
        }
      },
      "required": [
        "householdMembers",
        "energyExpense"
      ],
      "description": "Съдържание на съобщението"
    }
  },
  "required": [
    "header",
    "contents"
  ]
}