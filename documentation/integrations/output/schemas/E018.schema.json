{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:energy:messages:E018",
  "title": "E018 – Потвърждение за промяна на титуляр",
  "type": "object",
  "properties": {
    "header": {
      "type": "object",
      "properties": {
        "sender": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "description": "Тип изпращач на съобщението"
        },
        "senderISName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Име и версия на информационната система, изпратила съобщението"
        },
        "recipient": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "description": "Тип на получател на съобщението"
        },
        "messageId": {
          "type": "string",
          "format": "uuid",
          "minLength": 36,
          "maxLength": 36,
          "description": "Уникален идентификатор на текущото съобщение"
        },
        "messageType": {
          "type": "string",
          "const": "E018",
          "description": "Тип на съобщението"
        },
        "createdOn": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}:\\d{2}[+-]\\d{2}:\\d{2}$",
          "description": "Дата и час на изготвяне на съобщението по ISO 8601 в локално време с часова зона"
        }
      },
      "required": [
        "sender",
        "senderISName",
        "recipient",
        "messageId",
        "messageType",
        "createdOn"
      ],
      "description": "Системна информация за съобщението"
    },
    "contents": {
      "type": "object",
      "properties": {
        "resultCode": {
          "type": "string",
          "enum": [
            "BPL",
            "APL",
            "DF",
            "NDF",
            "SCNF",
            "OCNF"
          ],
          "description": "Код на резултата от проверката | Rules: RL005"
        },
        "resultDescription": {
          "type": "string",
          "maxLength": 500,
          "description": "Допълнително пояснение към резултата от проверката"
        },
        "measurementPoint": {
          "type": "object",
          "properties": {
            "measurementPointNumber": {
              "type": "string",
              "maxLength": 50,
              "description": "Номер на измервателна точка"
            },
            "clientNumber": {
              "type": "string",
              "maxLength": 50,
              "description": "Клиентски номер"
            },
            "subscriberNumber": {
              "type": "string",
              "maxLength": 50,
              "description": "Абонатен номер"
            }
          },
          "anyOf": [
            {
              "required": [
                "clientNumber"
              ]
            },
            {
              "required": [
                "measurementPointNumber"
              ]
            },
            {
              "required": [
                "subscriberNumber"
              ]
            }
          ],
          "description": "Данни за измервателна точка"
        }
      },
      "required": [
        "resultCode",
        "measurementPoint"
      ],
      "description": "Съдържание на съобщението"
    }
  },
  "required": [
    "header",
    "contents"
  ]
}