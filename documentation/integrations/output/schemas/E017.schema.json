{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:energy:messages:E017",
  "title": "E017 – Заявка за промяна на титуляр",
  "type": "object",
  "properties": {
    "header": {
      "type": "object",
      "properties": {
        "sender": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "description": "Тип изпращач на съобщението"
        },
        "senderISName": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "description": "Име и версия на информационната система, изпратила съобщението"
        },
        "recipient": {
          "type": "string",
          "enum": [
            "1",
            "2",
            "3",
            "4",
            "5",
            "6",
            "7",
            "8"
          ],
          "description": "Тип на получател на съобщението"
        },
        "messageId": {
          "type": "string",
          "format": "uuid",
          "minLength": 36,
          "maxLength": 36,
          "description": "Уникален идентификатор на съобщението - трябва да бъде ново UUID генерирано към момента на изпращане на съобщението"
        },
        "messageType": {
          "type": "string",
          "const": "E017",
          "description": "Тип на съобщението"
        },
        "createdOn": {
          "type": "string",
          "pattern": "^\\d{2}-\\d{2}-\\d{4} \\d{2}:\\d{2}:\\d{2}[+-]\\d{2}:\\d{2}$",
          "description": "Дата и час на изготвяне на съобщението по ISO 8601 в локално време с часова зона"
        }
      },
      "required": [
        "sender",
        "senderISName",
        "recipient",
        "messageId",
        "messageType",
        "createdOn"
      ],
      "description": "Системна информация за съобщението"
    },
    "contents": {
      "type": "object",
      "properties": {
        "newOwner": {
          "type": "object",
          "properties": {
            "identifierType": {
              "type": "string",
              "enum": [
                "1",
                "2",
                "3"
              ],
              "description": "Вид идентификатор"
            },
            "identifier": {
              "type": "string",
              "description": "ЕГН/ЛНЧ/ЛН | Rules: RL001"
            },
            "firstName": {
              "type": "string",
              "maxLength": 50,
              "description": "Собствено име"
            },
            "middleName": {
              "type": "string",
              "maxLength": 50,
              "description": "Бащино име"
            },
            "lastName": {
              "type": "string",
              "maxLength": 50,
              "description": "Фамилия"
            }
          },
          "required": [
            "identifierType",
            "identifier",
            "firstName",
            "lastName"
          ],
          "description": "Нов титуляр на партида"
        },
        "measurementPoint": {
          "type": "object",
          "properties": {
            "measurementPointNumber": {
              "type": "string",
              "maxLength": 50,
              "description": "Номер на измервателна точка"
            },
            "clientNumber": {
              "type": "string",
              "maxLength": 50,
              "description": "Клиентски номер"
            },
            "subscriberNumber": {
              "type": "string",
              "maxLength": 50,
              "description": "Абонатен номер"
            }
          },
          "anyOf": [
            {
              "required": [
                "clientNumber"
              ]
            },
            {
              "required": [
                "measurementPointNumber"
              ]
            },
            {
              "required": [
                "subscriberNumber"
              ]
            }
          ],
          "description": "Данни за измервателна точка"
        }
      },
      "required": [
        "newOwner",
        "measurementPoint"
      ],
      "description": "Съдържание на съобщението"
    }
  },
  "required": [
    "header",
    "contents"
  ]
}